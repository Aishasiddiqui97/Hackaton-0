# Environment Variables Template
# Copy this file to .env and fill in your actual credentials

# ============================================
# Odoo Accounting Integration
# ============================================
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=USER NAME
ODOO_PASSWORD=password

# ============================================
# Facebook Business API
# ============================================
FACEBOOK_ACCESS_TOKEN= FACKBOOK_API_KEY
FACEBOOK_PAGE_ID= PAGE ID

# ============================================
# Instagram Business API
# ============================================
INSTAGRAM_ACCESS_TOKEN=INSTAGRAM_API_KEY
INSTAGRAM_ACCOUNT_ID=INSTAGRAM_ID

# ============================================
# Twitter (X) API v2
# ============================================
TWITTER_BEARER_TOKEN=TOKEN 
TWITTER_API_KEY=API_KEY
TWITTER_API_SECRET=API_SECRET
TWITTER_ACCESS_TOKEN=ACCESS_TOKEN
TWITTER_ACCESS_TOKEN_SECRET=SECERET_KEY
# ============================================
# Gmail API (Already configured)
# ============================================
GMAIL_CHECK_INTERVAL=60

# ============================================
# LinkedIn (Already configured)
# ============================================
LINKEDIN_EMAIL=EMAIL
LINKEDIN_PASSWORD=PASWORD
LINKEDIN_CHECK_INTERVAL=120

# ============================================
# Twitter/X Credentials (Browser Automation)
# ============================================
TWITTER_EMAIL=
TWITTER_USERNAME=
TWITTER_PASSWORD=
# Optional: Add 2FA secret for automatic login (base32 format from authenticator app)
# To get the 2FA secret: In Twitter Settings > Security > 2FA > App > "Can't scan QR code?" to see key
TWITTER_2FA_SECRET=

# ============================================
# Facebook Credentials
# ============================================
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=
# ============================================
# Instagram (via Facebook)
# ============================================
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ============================================
# WhatsApp (Already configured)
# ============================================
WHATSAPP_CHECK_INTERVAL=90
GEMINI_API_KEY=
# ============================================
# SMTP Email (Already configured)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true

# ============================================
# System Configuration
# ============================================
LOG_LEVEL=INFO
CEO_BRIEFING_DAY=Monday
CEO_BRIEFING_HOUR=8

